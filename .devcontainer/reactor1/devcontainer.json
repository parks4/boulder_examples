{
  "name": "Boulder - Constant-pressure ignition",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": "../.."
  },
  "forwardPorts": [
    8050
  ],
  "postCreateCommand": "conda env update -n boulder -f environment.yml --prune",
  "postAttachCommand": "conda run -n boulder boulder examples/reactor1.yaml --host 0.0.0.0 --no-open",
  "remoteEnv": {
    "PATH": "/opt/conda/envs/boulder/bin:${containerEnv:PATH}"
  },
  "portsAttributes": {
    "8050": {
      "label": "Boulder - Constant-pressure ignition",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff"
      ]
    }
  },
  "remoteUser": "vscode"
}
