{
  "name": "Boulder - Mixer with two inlet streams",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": "../.."
  },
  "forwardPorts": [
    8050
  ],
  "postCreateCommand": "conda env update -n boulder-examples -f environment.yml --prune",
  "postAttachCommand": "conda run -n boulder-examples boulder examples/mix1.yaml --host 0.0.0.0 --no-open",
  "portsAttributes": {
    "8050": {
      "label": "Boulder - Mixer with two inlet streams",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff"
      ]
    }
  },
  "remoteUser": "vscode"
}
