{
  "name": "Boulder Examples",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "forwardPorts": [8050],
  "postCreateCommand": "conda env update -n boulder-examples -f environment.yml --prune",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff"
      ]
    }
  },
  "remoteUser": "vscode"
}
